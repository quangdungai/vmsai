# ============================================================
# SERVER
# ============================================================
HOST=0.0.0.0
PORT=8000
DEBUG=False

# ============================================================
# CAMERA - Hỗ trợ: USB camera (0,1,2...), RTSP IP stream
# ============================================================
CAMERA_SOURCE=0
CAMERA_FPS=25
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
FRAME_SKIP=3
PROCESS_WIDTH=640
STREAM_WIDTH=640
STREAM_FPS=12
STREAM_JPEG_QUALITY=60
DETECTION_SIZE=320

# ============================================================
# FACE DETECTION & RECOGNITION
# ============================================================
DETECTION_MODEL=buffalo_l
DETECTION_THRESHOLD=0.7
MIN_FACE_SIZE=80
MAX_FACE_SIZE=600
DETECTION_BACKEND=cpu
RECOGNITION_THRESHOLD=0.45
RECOGNITION_MARGIN=0.08
STRICT_MODE=True

# ============================================================
# FACE ANTI-SPOOFING (FAS) - 5 tầng bảo vệ
# ============================================================
FAS_TEXTURE_ENABLED=True
FAS_TEXTURE_THRESHOLD=0.75
FAS_LIVENESS_ENABLED=True
FAS_LIVENESS_FRAMES=15
FAS_BLINK_REQUIRED=True
FAS_HEAD_MOTION_REQUIRED=True
FAS_FREQ_ENABLED=True
FAS_FREQ_THRESHOLD=0.7
FAS_TEMPORAL_ENABLED=True
FAS_TEMPORAL_FRAMES=20
FAS_DL_ENABLED=True
FAS_FINAL_THRESHOLD=0.80
FAS_MIN_LAYERS_PASS=4

# Xác minh đa khung hình trước khi chấm công
ATTENDANCE_CONFIRM_FRAMES=5
ATTENDANCE_CONFIRM_TIMEOUT_SEC=3.0

# ============================================================
# CHẤM CÔNG
# ============================================================
ATTENDANCE_COOLDOWN_MINUTES=30
CHECKIN_LATE_THRESHOLD=08:30
CHECKOUT_EARLY_THRESHOLD=17:30

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=sqlite+aiosqlite:///./data/attendance.db

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
LOG_ATTENDANCE_IMAGES=True
AUDIT_LOG_INTERVAL=30
